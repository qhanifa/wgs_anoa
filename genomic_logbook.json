      "timestamp": "2026-05-16T21:44:41",
      "date": "2026-05-16",
      "analyst": "qonitahanifa",
      "title": "Re-run Variant Filtering - bcftools filter",
      "tool": "bcftools filter",
      "output_dir": "anoa_analysis/filtered",
      "status": "completed",
      "notes": "previous run skipped MAF and F_MISSING silently, filtering incomplete. current run adds bcftools +fill tags to calculate both columns",
      "tags": [
        "filtering"
      ],
      "project": "anoa_wgs",
      "sample_ids": [],
      "organism": "BDBQ",
      "tool_version": "",
      "script": "bcftools view \\",
      "command": "    -m2 -M2 \\\n    -v snps \\\n    -O u \\\n    $VCF_DIR/raw_variants.vcf.gz | \\\nbcftools +fill-tags \\\n    -O u -- -t MAF,F_MISSING | \\\nbcftools filter \\\n    -e 'MAF<0.05 || F_MISSING>0.05 || AC==0 || AC==AN' \\\n    -O z \\\n    --threads 8 \\\n    -o $OUT/filtered_snps.vcf.gz",
      "job_id": "bcftools index -t $OUT/filtered_snps.vcf.gz 482674",
      "cluster": "trembesi53",
