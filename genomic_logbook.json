    {
      "id": 13,
      "timestamp": "2026-05-16T21:44:41",
      "date": "2026-05-16",
      "analyst": "qonitahanifa",
      "title": "Re-run Variant Filtering - bcftools filter",
      "tool": "bcftools filter",
      "output_dir": "anoa_analysis/filtered",
      "status": "completed",
      "notes": "previous run skipped MAF and F_MISSING silently, filtering incomplete. current run adds bcftools +fill tags to calculate both columns",
      "tags": [
        "variant-calling"
      ],
      "project": "anoa_wgs",
      "sample_ids": [],
      "organism": "BDBQ",
      "tool_version": "",
      "script": "bcftools view \\",
      "command": "    -m2 -M2 \\\n    -v snps \\\n    -O u \\\n    $VCF_DIR/raw_variants.vcf.gz | \\\nbcftools +fill-tags \\\n    -O u -- -t MAF,F_MISSING | \\\nbcftools filter \\\n    -e 'MAF<0.05 || F_MISSING>0.05 || AC==0 || AC==AN' \\\n    -O z \\\n    --threads 8 \\\n    -o $OUT/filtered_snps.vcf.gz",
      "job_id": "bcftools index -t $OUT/filtered_snps.vcf.gz 482674",
      "cluster": "trembesi53",
      "cpus": "8",
      "mem": "16G",
      "walltime": "04:00:00",
      "input_files": "raw_variants.vcf.gz",
      "ref_genome": "btau9",
      "results": "identical results with previous filtering job (481641)"
    },
    {
      "id": 14,
      "timestamp": "2026-05-17T05:59:51",
      "date": "2026-05-17",
      "analyst": "qonitahanifa",
      "title": "Outgroup Variant Calling - bcftools mpileup + call",
      "tool": "bcftools mpileup",
      "output_dir": "anoa_analysis/outgroup",
      "status": "completed",
      "notes": "calling all chromosome at once for 1 outgroup",
      "tags": [
        "outgroup",
        "variant-calling"
      ],
      "project": "anoa_wgs",
      "sample_ids": [],
      "organism": "Syncerus.sp",
      "tool_version": "1.23",
      "script": "bcftools mpileup \\",
      "command": "    -f $REF \\\n    -a AD,DP \\\n    $OUT_DIR/african_buffalo.sorted.dedup.bam \\\n    -q 20 -Q 20 \\\n    --rf 3 \\\n    --threads 8 \\\n    -O u | \\\nbcftools call \\\n    -m \\\n    --ploidy 2 \\\n    --threads 8 \\\n    -f GQ \\\n    -Oz -o ${OUT_DIR}/buffalo_all_chr.vcf.gz",
      "job_id": "482736",
      "cluster": "trembesi53",
      "cpus": "8",
      "mem": "16",
      "walltime": "12:00:00",
      "input_files": "african_buffalo.sorted.dedup.bam",
      "ref_genome": "btau9",
      "results": "finished in 3h 50 m"
    },
